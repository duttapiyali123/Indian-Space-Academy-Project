        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import random\n",
        "from google.colab import files\n",
        "\n",
        "# --- 1. Parameters ---\n",
        "num_agents = 3\n",
        "iterations = 30\n",
        "# Initial predictions for 'Forest' class: ViT (0.9), CNN (0.3), RF (0.2)\n",
        "initial_opinions = np.array([0.9, 0.3, 0.2])\n",
        "\n",
        "# --- 2. Static Platooning ---\n",
        "# Hub topology\n",
        "A_static = np.array([[1, 1, 1], [1, 1, 0], [1, 0, 1]])\n",
        "W_static = A_static / A_static.sum(axis=1, keepdims=True)\n",
        "static_hist = np.zeros((iterations, num_agents))\n",
        "static_hist[0] = initial_opinions\n",
        "curr_static = initial_opinions.copy()\n",
        "for t in range(1, iterations):\n",
        "    curr_static = np.dot(W_static, curr_static)\n",
        "    static_hist[t] = curr_static\n",
        "\n",
        "# --- 3. Dynamic Platooning ---\n",
        "# Intermittent topology: Agent 2 (RF) loses connection 50% of the time\n",
        "dynamic_hist = np.zeros((iterations, num_agents))\n",
        "dynamic_hist[0] = initial_opinions\n",
        "curr_dynamic = initial_opinions.copy()\n",
        "for t in range(1, iterations):\n",
        "    if random.random() > 0.5:\n",
        "        # Fully connected\n",
        "        A_dyn = np.array([[1, 1, 1], [1, 1, 1], [1, 1, 1]])\n",
        "    else:\n",
        "        # Disconnected (Only ViT and CNN talk)\n",
        "        A_dyn = np.array([[1, 1, 0], [1, 1, 0], [0, 0, 1]])\n",
        "    W_dyn = A_dyn / A_dyn.sum(axis=1, keepdims=True)\n",
        "    curr_dynamic = np.dot(W_dyn, curr_dynamic)\n",
        "    dynamic_hist[t] = curr_dynamic\n",
        "\n",
        "# --- 4. Plotting Comparison ---\n",
        "fig, axes = plt.subplots(1, 3, figsize=(20, 6))\n",
        "colors = ['blue', 'orange', 'green']\n",
        "labels = ['Agent 0 (ViT)', 'Agent 1 (CNN)', 'Agent 2 (RF)']\n",
        "\n",
        "# Panel 1: Individual Models (No Consensus)\n",
        "for i in range(num_agents):\n",
        "    axes[0].axhline(y=initial_opinions[i], color=colors[i], label=labels[i], linewidth=2)\n",
        "axes[0].set_title(\"1. Individual Models (Baseline)\", fontsize=14)\n",
        "axes[0].set_ylabel(\"Probability\")\n",
        "axes[0].set_ylim(0, 1.0)\n",
        "axes[0].legend()\n",
        "\n",
        "# Panel 2: Static Platooning\n",
        "for i in range(num_agents):\n",
        "    axes[1].plot(range(iterations), static_hist[:, i], color=colors[i], marker='o', markersize=4)\n",
        "axes[1].set_title(\"2. Static Platooning (Fixed)\", fontsize=14)\n",
        "axes[1].set_ylim(0, 1.0)\n",
        "\n",
        "# Panel 3: Dynamic Platooning\n",
        "for i in range(num_agents):\n",
        "    axes[2].plot(range(iterations), dynamic_hist[:, i], color=colors[i], marker='x', markersize=4)\n",
        "axes[2].set_title(\"3. Dynamic Platooning (Intermittent)\", fontsize=14)\n",
        "axes[2].set_ylim(0, 1.0)\n",
        "\n",
        "plt.tight_layout()\n",
        "save_path = 'Platooning_Comparison_Analysis.png'\n",
