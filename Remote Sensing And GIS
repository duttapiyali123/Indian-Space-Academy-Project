      "source": [
        "import matplotlib.pyplot as plt\n",
        "import cv2\n",
        "import numpy as np\n",
        "\n",
        "def calculate_greenness_index(img_bgr):\n",
        "    img = img_bgr.astype(float)\n",
        "    G = img[:, :, 1]\n",
        "    R = img[:, :, 2]\n",
        "    index = (G - R) / (G + R + 1e-6)\n",
        "    return index\n",
        "\n",
        "# Expanded to 6 classes\n",
        "six_classes = ['Forest', 'AnnualCrop', 'Industrial', 'Residential', 'HerbaceousVegetation', 'Highway']\n",
        "data_dir = 'eurosat_data/EuroSAT_RGB'\n",
        "\n",
        "# Create a larger figure for 6 individual comparisons\n",
        "fig, axes = plt.subplots(6, 2, figsize=(12, 24))\n",
        "\n",
        "for i, class_name in enumerate(six_classes):\n",
        "    class_path = os.path.join(data_dir, class_name)\n",
        "    img_name = os.listdir(class_path)[0]\n",
        "    img_path = os.path.join(class_path, img_name)\n",
        "    img_bgr = cv2.imread(img_path)\n",
        "\n",
        "    index_map = calculate_greenness_index(img_bgr)\n",
        "    mean_val = np.mean(index_map)\n",
        "\n",
        "    # Original View\n",
        "    axes[i, 0].imshow(cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB))\n",
        "    axes[i, 0].set_title(f'Original: {class_name}')\n",
        "    axes[i, 0].axis('off')\n",
        "\n",
        "    # Greenness Index Map\n",
        "    im = axes[i, 1].imshow(index_map, cmap='RdYlGn')\n",
        "    axes[i, 1].set_title(f'{class_name} Greenness (Mean: {mean_val:.4f})')\n",
        "    axes[i, 1].axis('off')\n",
        "    fig.colorbar(im, ax=axes[i, 1])\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
