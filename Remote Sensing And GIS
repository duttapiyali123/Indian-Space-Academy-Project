        "import matplotlib.pyplot as plt\n",
        "import cv2\n",
        "import numpy as np\n",
        "import os\n",
        "\n",
        "def calculate_greenness_index(img_bgr):\n",
        "    # Formula: (Green - Red) / (Green + Red + 1e-6)\n",
        "    # OpenCV loads images as BGR, so index 1 is Green and index 2 is Red\n",
        "    img = img_bgr.astype(float)\n",
        "    G = img[:, :, 1]\n",
        "    R = img[:, :, 2]\n",
        "    index = (G - R) / (G + R + 1e-6)\n",
        "    return index\n",
