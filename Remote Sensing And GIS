        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "from torchvision import datasets, transforms, models\n",
        "from torch.utils.data import DataLoader, random_split\n",
        "from sklearn.ensemble import RandomForestClassifier\n",
        "import joblib\n",
        "import numpy as np\n",
        "import os\n",
        "import zipfile\n",
        "\n",
        "# 1. Robust Repair and Extraction\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "extract_path = 'eurosat_data'\n",
        "data_dir = os.path.join(extract_path, 'EuroSAT_RGB')\n",
        "zip_path = '/content/EuroSAT_RGB.zip'\n",
        "fixed_zip = '/content/fixed_EuroSAT.zip'\n",
        "\n",
        "if not os.path.exists(data_dir):\n",
        "    if os.path.exists(zip_path):\n",
        "        print('Attempting to repair and extract zip archive...')\n",
        "        # Use system tools to repair the zip if it's corrupted\n",
        "        !zip -FF {zip_path} --out {fixed_zip}\n",
        "        !unzip -qo {fixed_zip} -d {extract_path}\n",
        "\n",
        "        # Verification\n",
        "        if not os.path.exists(data_dir):\n",
        "            # Check if it extracted to a different nested folder\n",
        "            potential_path = os.path.join(extract_path, '2750')\n",
        "            if os.path.exists(potential_path):\n",
        "                os.rename(potential_path, data_dir)\n",
        "\n",
        "        if os.path.exists(data_dir):\n",
        "            print('Extraction complete.')\n",
        "        else:\n",
        "            raise FileNotFoundError('Extraction failed. Please verify the contents of the zip file.')\n",
        "    else:\n",
        "        raise FileNotFoundError(f'{zip_path} not found.')\n",
        "\n",
        "# 2. Fast Training for Agent 1 (CNN/ResNet50)\n",
        "print('\\n--- Retraining Agent 1 (CNN) ---')\n",
        "transform_dl = transforms.Compose([\n",
        "    transforms.Resize((224, 224)),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "full_dataset = datasets.ImageFolder(root=data_dir, transform=transform_dl)\n",
        "train_size = int(0.8 * len(full_dataset))\n",
        "val_size = len(full_dataset) - train_size\n",
        "train_ds, _ = random_split(full_dataset, [train_size, val_size], generator=torch.Generator().manual_seed(42))\n",
        "train_loader = DataLoader(train_ds, batch_size=64, shuffle=True)\n",
        "\n",
        "cnn = models.resnet50(weights=models.ResNet50_Weights.DEFAULT)\n",
        "for param in cnn.parameters(): param.requires_grad = False\n",
        "cnn.fc = nn.Linear(cnn.fc.in_features, 10)\n",
        "cnn.to(device)\n",
        "\n",
        "criterion = nn.CrossEntropyLoss()\n",
        "optimizer = optim.Adam(cnn.fc.parameters(), lr=0.001)\n",
        "\n",
        "for epoch in range(3):\n",
        "    cnn.train()\n",
        "    for imgs, lbls in train_loader:\n",
        "        imgs, lbls = imgs.to(device), lbls.to(device)\n",
        "        optimizer.zero_grad()\n",
        "        outputs = cnn(imgs)\n",
        "        loss = criterion(outputs, lbls)\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "    print(f'Epoch {epoch+1}/3 Complete')\n",
        "\n",
        "torch.save(cnn.state_dict(), '/content/Agent_1_CNN.pth')\n",
        "print('✅ Agent 1 Saved.')\n",
        "\n",
        "# 3. Fast Training for Agent 2 (Random Forest)\n",
        "print('\\n--- Retraining Agent 2 (RF) ---')\n",
        "transform_rf = transforms.Compose([transforms.Resize((64, 64)), transforms.ToTensor()])\n",
        "rf_dataset = datasets.ImageFolder(root=data_dir, transform=transform_rf)\n",
        "rf_train_ds, _ = random_split(rf_dataset, [train_size, val_size], generator=torch.Generator().manual_seed(42))\n",
        "\n",
        "X_train, y_train = [], []\n",
        "for i in range(2000):\n",
        "    img, lbl = rf_train_ds[i]\n",
        "    X_train.append(img.view(-1).numpy())\n",
        "    y_train.append(lbl)\n",
        "\n",
        "rf_model = RandomForestClassifier(n_estimators=50, n_jobs=-1)\n",
        "rf_model.fit(X_train, y_train)\n",
        "joblib.dump(rf_model, '/content/Agent_2_RF.joblib')\n",
        "print('✅ Agent 2 Saved.')"
      ]
    },
