        "import numpy as np\n",
        "from sklearn.metrics import accuracy_score, f1_score\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# --- 1. Load the Extracted Opinions (Probabilities) ---\n",
        "print(\"Loading probability distributions from Agents...\")\n",
        "vit_probs = np.load('/content/vit_opinions.npy')\n",
        "cnn_probs = np.load('/content/cnn_opinions.npy')\n",
        "rf_probs = np.load('/content/rf_opinions.npy')\n",
        "true_labels = np.load('/content/true_labels.npy')\n",
        "\n",
        "num_samples = len(true_labels)\n",
        "num_classes = 10\n",
        "num_agents = 3\n",
        "\n",
        "# Stack opinions into a single tensor of shape: (samples, agents, classes)\n",
        "opinions = np.stack([vit_probs, cnn_probs, rf_probs], axis=1)\n",
        "\n",
        "# --- 2. Define the Static Platoon Topology ---\n",
        "# Agent 0 (ViT) acts as the central hub communicating with both Agent 1 (CNN) and Agent 2 (RF)\n",
        "adjacency_matrix = np.array([\n",
        "    [1, 1, 1], # ViT listens to itself, CNN, RF\n",
        "    [1, 1, 0], # CNN listens to ViT and itself\n",
        "    [1, 0, 1]  # RF listens to ViT and itself\n",
        "])\n",
        "\n",
        "# Create the row-stochastic Weight Matrix for the DeGroot model\n",
        "weight_matrix = adjacency_matrix / adjacency_matrix.sum(axis=1, keepdims=True)\n",
        "\n",
        "# --- 3. The Mathematical Consensus Loop ---\n",
        "iterations = 10\n",
        "print(f\"Executing Opinion Dynamics Loop for {iterations} iterations over {num_samples} images...\")\n",
        "\n",
        "# We use Einstein summation (np.einsum) to efficiently apply the weight matrix\n",
        "# across all samples and classes simultaneously.\n",
        "for t in range(iterations):\n",
        "    # This mathematically calculates: new_opinions = W * opinions\n",
        "    opinions = np.einsum('ij,sjc->sic', weight_matrix, opinions)\n",
        "\n",
        "# --- 4. Extract Final Swarm Predictions ---\n",
        "# After consensus, all connected agents share the exact same probability distribution.\n",
        "# We extract the final agreed-upon probabilities and take the argmax for the class prediction.\n",
        "final_swarm_probs = opinions[:, 0, :]\n",
        "swarm_preds = np.argmax(final_swarm_probs, axis=1)\n",
        "\n",
        "# Get baseline predictions for comparison\n",
        "vit_preds = np.argmax(vit_probs, axis=1)\n",
        "cnn_preds = np.argmax(cnn_probs, axis=1)\n",
        "rf_preds = np.argmax(rf_probs, axis=1)\n",
        "\n",
        "# --- 5. Benchmarking Defense-Aware Swarm vs. Individuals ---\n",
        "agents = ['Agent 0 (ViT)', 'Agent 1 (CNN)', 'Agent 2 (RF)', 'Swarm Consensus']\n",
        "preds_list = [vit_preds, cnn_preds, rf_preds, swarm_preds]\n",
        "\n",
        "accuracies = [accuracy_score(true_labels, p) * 100 for p in preds_list]\n",
        "f1_scores = [f1_score(true_labels, p, average='weighted') * 100 for p in preds_list]\n",
        "\n",
        "print(\"\\n\" + \"=\"*55)\n",
        "print(\"FINAL CONSENSUS BENCHMARKING RESULTS\")\n",
        "print(\"=\"*55)\n",
        "for i, agent in enumerate(agents):\n",
        "    print(f\"{agent: <20} | Accuracy: {accuracies[i]:.2f}% | F1-Score: {f1_scores[i]:.2f}\")\n",
        "\n",
        "# --- 6. Generate the Final Proof Graph for the Paper ---\n",
        "x = np.arange(len(agents))\n",
        "width = 0.35\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 6))\n",
        "# Using distinct colors to differentiate the swarm from single agents\n",
        "rects1 = ax.bar(x - width/2, accuracies, width, label='Accuracy (%)', color='mediumpurple')\n",
        "rects2 = ax.bar(x + width/2, f1_scores, width, label='F1-Score (x100)', color='lightseagreen')\n",
        "\n",
        "ax.set_ylabel('Scores')\n",
        "ax.set_title('Benchmarking Single Agents vs. Multi-Agent Swarm Consensus')\n",
        "ax.set_xticks(x)\n",
        "ax.set_xticklabels(agents, fontweight='bold')\n",
        "ax.legend(loc='lower right')\n",
        "ax.set_ylim(0, 110)\n",
        "\n",
        "ax.bar_label(rects1, padding=3, fmt='%.1f')\n",
        "ax.bar_label(rects2, padding=3, fmt='%.1f')\n",
        "\n",
        "# Highlight the Swarm Consensus on the x-axis\n",
        "ax.get_xticklabels()[3].set_color('darkred')\n",
        "\n",
        "plt.tight_layout()\n",
        "consensus_chart_path = '/content/Swarm_Consensus_Results.png'\n",
        "plt.savefig(consensus_chart_path, dpi=300)\n",
        "plt.show()\n",
        "\n",
        "print(f\"\\nSaved consensus benchmarking chart to: {consensus_chart_path}\")"
      ]
