        "import matplotlib.pyplot as plt\n",
        "import cv2\n",
        "import numpy as np\n",
        "import os\n",
        "from google.colab import files\n",
        "\n",
        "def calculate_greenness_index(img_bgr):\n",
        "    img = img_bgr.astype(float)\n",
        "    G = img[:, :, 1]\n",
        "    R = img[:, :, 2]\n",
        "    index = (G - R) / (G + R + 1e-6)\n",
        "    return index\n",
        "\n",
        "# Create a directory to store the results\n",
        "output_folder = 'eurosat_greenness_results'\n",
        "os.makedirs(output_folder, exist_ok=True)\n",
        "\n",
        "six_classes = ['Forest', 'AnnualCrop', 'Industrial', 'Residential', 'HerbaceousVegetation', 'Highway']\n",
        "data_dir = 'eurosat_data/EuroSAT_RGB'\n",
        "\n",
        "# Wait for extraction to complete if running manually\n",
        "if not os.path.exists(data_dir):\n",
        "    # Some zip structures might have a nested folder\n",
        "    data_dir = 'eurosat_data/2750/EuroSAT_RGB'\n",
        "\n",
        "fig, axes = plt.subplots(6, 2, figsize=(12, 24))\n",
        "\n",
        "for i, class_name in enumerate(six_classes):\n",
        "    class_path = os.path.join(data_dir, class_name)\n",
        "    if os.path.exists(class_path):\n",
        "        img_list = os.listdir(class_path)\n",
        "        img_name = img_list[0]\n",
        "        img_path = os.path.join(class_path, img_name)\n",
        "        img_bgr = cv2.imread(img_path)\n",
        "\n",
        "        index_map = calculate_greenness_index(img_bgr)\n",
        "        mean_val = np.mean(index_map)\n",
        "\n",
        "        # Original View\n",
        "        axes[i, 0].imshow(cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB))\n",
        "        axes[i, 0].set_title(f'Original: {class_name}')\n",
        "        axes[i, 0].axis('off')\n",
        "\n",
        "        # Save original image to Colab disk\n",
        "        orig_filename = os.path.join(output_folder, f'{class_name}_original.png')\n",
        "        cv2.imwrite(orig_filename, img_bgr)\n",
        "\n",
        "        # Greenness Index Map\n",
        "        im = axes[i, 1].imshow(index_map, cmap='RdYlGn')\n",
        "        axes[i, 1].set_title(f'{class_name} Greenness (Mean: {mean_val:.4f})')\n",
        "        axes[i, 1].axis('off')\n",
        "        fig.colorbar(im, ax=axes[i, 1])\n",
        "\n",
        "        # Save greenness map\n",
        "        map_filename = os.path.join(output_folder, f'{class_name}_greenness_map.png')\n",
        "        plt.imsave(map_filename, index_map, cmap='RdYlGn')\n",
        "    else:\n",
        "        print(f'Warning: Class path {class_path} not found.')\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Automatically download all saved files\n",
        "print('Initiating downloads from Colab to local system...')\n",
        "for filename in os.listdir(output_folder):\n",
        "    full_path = os.path.join(output_folder, filename)\n",
        "    files.download(full_path)"
      ]
