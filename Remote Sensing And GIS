        "import torch\n",
        "import torch.nn as nn\n",
        "from torchvision import datasets, transforms, models\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import cv2\n",
        "import os\n",
        "from google.colab import files\n",
        "from pytorch_grad_cam import GradCAM\n",
        "from pytorch_grad_cam.utils.image import show_cam_on_image\n",
        "from pytorch_grad_cam.utils.model_targets import ClassifierOutputTarget\n",
        "import zipfile\n",
        "\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "\n",
        "# --- Ensure Data is Extracted and Available ---\n",
        "data_dir = 'eurosat_data/EuroSAT_RGB'\n",
        "if not os.path.exists(data_dir):\n",
        "    print(\"Extracting dataset...\")\n",
        "    zip_path = '/content/EuroSAT_RGB.zip'\n",
        "    with zipfile.ZipFile(zip_path, 'r') as zip_ref:\n",
        "        zip_ref.extractall('eurosat_data')\n",
        "    print(\"Extraction complete!\")\n",
        "\n",
        "# --- Data Preparation for Training ---\n",
        "transform_train = transforms.Compose([\n",
        "    transforms.Resize((224, 224)),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "full_dataset = datasets.ImageFolder(root=data_dir, transform=transform_train)\n",
        "train_size = int(0.8 * len(full_dataset))\n",
        "val_size = len(full_dataset) - train_size\n",
        "train_dataset, _ = torch.utils.data.random_split(full_dataset, [train_size, val_size], generator=torch.Generator().manual_seed(42))\n",
        "train_loader = torch.utils.data.DataLoader(train_dataset, batch_size=32, shuffle=True, num_workers=2)\n",
        "\n",
        "# --- 0. Re-train Agent 0 (ViT) ---\n",
        "print(\"\\n--- Re-training Agent 0 (ViT) ---\")\n",
        "vit = models.vit_b_16(weights='DEFAULT')\n",
        "for param in vit.parameters(): # Freeze base for faster training\n",
        "    param.requires_grad = False\n",
        "vit.heads.head = nn.Linear(vit.heads.head.in_features, 10)\n",
        "vit = vit.to(device)\n",
        "criterion = nn.CrossEntropyLoss()\n",
        "optimizer = torch.optim.Adam(vit.heads.head.parameters(), lr=0.001)\n",
        "\n",
        "vit.train()\n",
        "for epoch in range(3): # Train for 3 epochs\n",
        "    for images, labels in train_loader:\n",
        "        images, labels = images.to(device), labels.to(device)\n",
        "        optimizer.zero_grad()\n",
        "        outputs = vit(images)\n",
        "        loss = criterion(outputs, labels)\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "    print(f\"ViT Epoch {epoch+1}/3 complete.\")\n",
        "torch.save(vit.state_dict(), '/content/Agent_0_ViT.pth')\n",
        "print(\"✅ Agent 0 (ViT) Saved.\")\n",
        "\n",
        "# --- 1. Re-train Agent 1 (CNN/ResNet50) ---\n",
        "print(\"\\n--- Re-training Agent 1 (CNN/ResNet50) ---\")\n",
        "cnn = models.resnet50(weights='DEFAULT')\n",
        "for param in cnn.parameters(): # Freeze base for faster training\n",
        "    param.requires_grad = False\n",
        "cnn.fc = nn.Linear(cnn.fc.in_features, 10)\n",
        "cnn = cnn.to(device)\n",
        "optimizer = torch.optim.Adam(cnn.fc.parameters(), lr=0.001)\n",
        "\n",
        "cnn.train()\n",
        "for epoch in range(3): # Train for 3 epochs\n",
        "    for images, labels in train_loader:\n",
        "        images, labels = images.to(device), labels.to(device)\n",
        "        optimizer.zero_grad()\n",
        "        outputs = cnn(images)\n",
        "        loss = criterion(outputs, labels)\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "    print(f\"CNN Epoch {epoch+1}/3 complete.\")\n",
        "torch.save(cnn.state_dict(), '/content/Agent_1_CNN.pth')\n",
        "print(\"✅ Agent 1 (CNN) Saved.\")\n",
        "\n",
        "# --- 2. Grad-CAM Setup ---\n",
        "cnn_target_layers = [cnn.layer4[-1]]\n",
        "\n",
        "def vit_reshape_transform(tensor, height=14, width=14):\n",
        "    result = tensor[:, 1:, :].reshape(tensor.size(0), height, width, tensor.size(2))\n",
        "    result = result.permute(0, 3, 1, 2)\n",
        "    return result\n",
        "\n",
        "vit_target_layers = [vit.encoder.layers[-1].ln_1]\n",
        "\n",
        "# --- 3. Prepare a 'SeaLake' Sample Image ---\n",
        "dataset = datasets.ImageFolder(root=data_dir)\n",
        "classes = dataset.classes\n",
        "\n",
        "# Find the first index belonging to 'SeaLake'\n",
        "target_class = 'SeaLake'\n",
        "sea_lake_idx = [i for i, (path, label) in enumerate(dataset.samples) if classes[label] == target_class][0]\n",
        "\n",
        "raw_image, true_label_idx = dataset[sea_lake_idx]\n",
        "class_name = classes[true_label_idx]\n",
        "\n",
        "transform_eval = transforms.Compose([\n",
        "    transforms.Resize((224, 224)),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225])\n",
        "])\n",
        "input_tensor = transform_eval(raw_image).unsqueeze(0).to(device)\n",
        "img_vis = np.float32(raw_image.resize((224, 224))) / 255.0\n",
        "\n",
        "# --- 4. Generate the Heatmaps ---\n",
        "print(f\"\\nGenerating SeaLake heatmaps for class: {class_name}...\")\n",
        "\n",
        "with GradCAM(model=cnn, target_layers=cnn_target_layers) as cam_cnn:\n",
        "    cnn_grayscale_cam = cam_cnn(input_tensor=input_tensor, targets=[ClassifierOutputTarget(true_label_idx)])[0, :]\n",
        "    cnn_visualization = show_cam_on_image(img_vis, cnn_grayscale_cam, use_rgb=True)\n",
        "\n",
        "with GradCAM(model=vit, target_layers=vit_target_layers, reshape_transform=vit_reshape_transform) as cam_vit:\n",
        "    vit_grayscale_cam = cam_vit(input_tensor=input_tensor, targets=[ClassifierOutputTarget(true_label_idx)])[0, :]\n",
        "    vit_visualization = show_cam_on_image(img_vis, vit_grayscale_cam, use_rgb=True)\n",
        "\n",
        "# --- 5. Plot ---\n",
        "fig, axes = plt.subplots(1, 3, figsize=(18, 6))\n",
        "fig.suptitle(f'Explainability Comparison (True Class: {class_name})', fontsize=18)\n",
        "\n",
        "axes[0].imshow(img_vis)\n",
        "axes[0].set_title('Original SeaLake Image')\n",
        "axes[0].axis('off')\n",
        "\n",
        "axes[1].imshow(cnn_visualization)\n",
        "axes[1].set_title('CNN: Water Surface Texture')\n",
        "axes[1].axis('off')\n",
        "\n",
        "axes[2].imshow(vit_visualization)\n",
        "axes[2].set_title('ViT: Global Water Attention')\n",
        "axes[2].axis('off')\n",
        "\n",
        "plt.tight_layout()\n",
