        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import networkx as nx\n",
        "import os\n",
        "from google.colab import files\n",
        "\n",
        "# --- 1. Simulation Setup ---\n",
        "num_agents = 3\n",
        "num_classes = 10\n",
        "iterations = 15\n",
        "\n",
        "# EuroSAT Classes\n",
        "classes = ['AnnualCrop', 'Forest', 'HerbaceousVegetation', 'Highway', 'Industrial', 'Pasture', 'PermanentCrop', 'Residential', 'River', 'SeaLake']\n",
        "target_class_idx = 1 # Forest\n",
        "\n",
        "# Initial dummy opinions for visualization\n",
        "opinions = np.zeros((num_agents, num_classes))\n",
        "opinions[0, target_class_idx] = 0.8  # ViT high confidence\n",
        "opinions[1, target_class_idx] = 0.3  # CNN lower\n",
        "opinions[2, target_class_idx] = 0.4  # RF medium\n",
        "opinions = opinions / (opinions.sum(axis=1, keepdims=True) + 1e-6)\n",
        "\n",
        "# Static Adjacency Matrix (Agent 0 is the hub)\n",
        "adjacency_matrix = np.array([\n",
        "    [1, 1, 1],\n",
        "    [1, 1, 0],\n",
        "    [1, 0, 1]\n",
        "])\n",
        "weight_matrix = adjacency_matrix / adjacency_matrix.sum(axis=1, keepdims=True)\n",
        "\n",
        "# Consensus Loop\n",
        "history = np.zeros((iterations, num_agents, num_classes))\n",
        "history[0] = opinions\n",
        "curr_ops = opinions.copy()\n",
        "for t in range(1, iterations):\n",
        "    curr_ops = np.dot(weight_matrix, curr_ops)\n",
        "    history[t] = curr_ops\n",
        "\n",
        "# --- 2. Plotting ---\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 6))\n",
        "\n",
        "# Topology Graph\n",
        "G = nx.from_numpy_array(adjacency_matrix - np.eye(num_agents))\n",
        "pos = nx.spring_layout(G)\n",
        "labels = {0: 'Agent 0\\n(ViT)', 1: 'Agent 1\\n(CNN)', 2: 'Agent 2\\n(RF)'}\n",
        "nx.draw(G, pos, with_labels=True, labels=labels, node_size=3000, node_color='skyblue',\n",
        "        font_size=10, font_weight='bold', edge_color='gray', width=2, ax=ax1)\n",
        "ax1.set_title(\"Static Platoon Communication Topology\", fontsize=14)\n",
        "\n",
        "# Convergence Graph\n",
        "colors = ['blue', 'orange', 'green']\n",
        "for i in range(num_agents):\n",
        "    ax2.plot(range(iterations), history[:, i, target_class_idx], marker='o', label=f'Agent {i}', color=colors[i])\n",
        "\n",
        "ax2.set_title(f\"Consensus Convergence: {classes[target_class_idx]}\", fontsize=14)\n",
        "ax2.set_xlabel(\"Iterations\")\n",
        "ax2.set_ylabel(\"Probability\")\n",
        "ax2.legend()\n",
        "ax2.grid(True, linestyle='--')\n",
        "\n",
        "plt.tight_layout()\n",
        "\n",
        "# Create output folder if it doesn't exist\n",
        "output_folder = 'eurosat_greenness_results'\n",
        "os.makedirs(output_folder, exist_ok=True)\n",
        "\n",
        "save_path = os.path.join(output_folder, 'Static_Platooning_Consensus.png')\n",
        "plt.savefig(save_path, dpi=300)\n",
        "plt.show()\n",
        "\n",
        "# Trigger Download\n",
        "print(f'Saved to {save_path}. Initiating download...')\n",
        "files.download(save_path)"
